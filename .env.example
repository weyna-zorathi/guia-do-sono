# ═══════════════════════════════════════════════════════
# GUIA DO SONO — Variáveis de Ambiente
# Adicione estas variáveis no painel Vercel:
# Settings → Environment Variables
# ═══════════════════════════════════════════════════════

# ── ANTHROPIC (obrigatório para o chat funcionar) ──────
# Gere em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── SUPABASE (autenticação + banco de dados) ───────────
# Encontre em: painel Supabase → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── STRIPE (pagamentos — ative quando lançar os planos) ─
# Gere em: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Crie os preços em: Stripe → Products → Add product
STRIPE_PRICE_PLUS=price_...
STRIPE_PRICE_PREMIUM=price_...

# ── APP ────────────────────────────────────────────────
NEXT_PUBLIC_URL=https://guiadosono.vercel.app
